local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

while true do
    local name = LocalPlayer.Name
    local jobId = game.JobId
    local status = "online"

    pcall(function()
        local url = "http://127.0.0.1:3000/status?name=" .. name .. "&jobid=" .. jobId .. "&status=" .. status
        game:HttpGet(url)
    end)

    task.wait(5)
end
